# Claude (Anthropic) API
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# X (Twitter) API v2 — Developer Portal で取得
X_API_KEY=xxxxxxxxxxxx
X_API_SECRET=xxxxxxxxxxxx
X_ACCESS_TOKEN=xxxxxxxxxxxx
X_ACCESS_TOKEN_SECRET=xxxxxxxxxxxx

# Instagram Graph API — Meta for Developers で取得
# 長期トークン（60日有効）と Instagram Business Account ID
IG_ACCESS_TOKEN=EAAxxxxxxxxxxxx
IG_USER_ID=17841xxxxxxxxxxxx

# 画像をホスティングする公開URLのベース
# GitHub Actions で main にコミットされたら raw.githubusercontent.com 経由で配信
# 例: https://raw.githubusercontent.com/<owner>/<repo>/main
PUBLIC_IMAGE_BASE_URL=https://raw.githubusercontent.com/your-name/claudecood-app/main

# どちらかをスキップしたい場合は false に（デフォルトは両方投稿）
POST_TO_X=true
POST_TO_INSTAGRAM=true

# ローカルテスト用：実際には投稿せず生成内容だけ確認
DRY_RUN=false
